[
  {
    "id": "00000000-0000-0000-0000-000000000001",
    "name": "(Example) Motion → MQTT Alert",
    "enabled": false,
    "triggers": [
      {
        "type": "vapix_event",
        "topic0": {"tnsaxis": "VideoAnalytics"},
        "topic1": {"tnsaxis": "MotionDetection"},
        "filter_key": "active",
        "filter_value": true
      }
    ],
    "trigger_logic": "OR",
    "conditions": [],
    "condition_logic": "AND",
    "actions": [
      {
        "type": "mqtt_publish",
        "topic": "cameras/{{camera.serial}}/motion",
        "payload": "{\"camera\":\"{{camera.serial}}\",\"model\":\"{{camera.model}}\",\"time\":\"{{timestamp}}\",\"active\":{{trigger.active}}}",
        "qos": 0,
        "retain": false
      }
    ],
    "cooldown": 10,
    "max_executions": 0,
    "tags": ["example", "motion", "mqtt"]
  },
  {
    "id": "00000000-0000-0000-0000-000000000002",
    "name": "(Example) Webhook → HTTP POST with Payload",
    "enabled": false,
    "triggers": [
      {
        "type": "http_webhook",
        "token": "change-me-to-a-secret"
      }
    ],
    "trigger_logic": "OR",
    "conditions": [],
    "condition_logic": "AND",
    "actions": [
      {
        "type": "http_request",
        "url": "https://example.com/notify",
        "method": "POST",
        "headers": "Content-Type: application/json",
        "body": "{\"camera\":\"{{camera.serial}}\",\"time\":\"{{timestamp}}\",\"source\":\"{{trigger.source}}\"}"
      }
    ],
    "cooldown": 0,
    "max_executions": 0,
    "tags": ["example", "webhook"]
  },
  {
    "id": "00000000-0000-0000-0000-000000000003",
    "name": "(Example) MQTT Message → Forward & Log",
    "enabled": false,
    "triggers": [
      {
        "type": "mqtt_message",
        "topic_filter": "cameras/command/#"
      }
    ],
    "trigger_logic": "OR",
    "conditions": [],
    "condition_logic": "AND",
    "actions": [
      {
        "type": "send_syslog",
        "message": "MQTT command received on {{trigger.topic}}: {{trigger.payload}}"
      },
      {
        "type": "mqtt_publish",
        "topic": "cameras/{{camera.serial}}/ack",
        "payload": "{\"received\":\"{{trigger.payload}}\",\"time\":\"{{timestamp}}\"}",
        "qos": 0,
        "retain": false
      }
    ],
    "cooldown": 0,
    "max_executions": 0,
    "tags": ["example", "mqtt"]
  },
  {
    "id": "00000000-0000-0000-0000-000000000004",
    "name": "(Example) Schedule → Overlay Text",
    "enabled": false,
    "triggers": [
      {
        "type": "schedule",
        "schedule_type": "daily_time",
        "time": "08:00",
        "days": [1, 2, 3, 4, 5]
      }
    ],
    "trigger_logic": "OR",
    "conditions": [],
    "condition_logic": "AND",
    "actions": [
      {
        "type": "overlay_text",
        "channel": 1,
        "text": "{{camera.model}} — {{date}}",
        "duration": 30,
        "position": "top",
        "text_color": "white"
      }
    ],
    "cooldown": 0,
    "max_executions": 0,
    "tags": ["example", "schedule", "overlay"]
  },
  {
    "id": "00000000-0000-0000-0000-000000000005",
    "name": "(Example) Motion → Start Recording (Business Hours)",
    "enabled": false,
    "triggers": [
      {
        "type": "vapix_event",
        "topic0": {"tnsaxis": "VideoAnalytics"},
        "topic1": {"tnsaxis": "MotionDetection"},
        "filter_key": "active",
        "filter_value": true
      }
    ],
    "trigger_logic": "OR",
    "conditions": [
      {
        "type": "time_window",
        "start": "08:00",
        "end": "18:00",
        "days": [1, 2, 3, 4, 5]
      }
    ],
    "condition_logic": "AND",
    "actions": [
      {
        "type": "recording",
        "operation": "start",
        "duration": 30
      }
    ],
    "cooldown": 30,
    "max_executions": 0,
    "tags": ["example", "motion", "recording"]
  }
]
