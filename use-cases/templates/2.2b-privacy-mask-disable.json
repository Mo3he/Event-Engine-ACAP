{
  "name": "Disable Privacy Mask — After Hours",
  "description": "At 18:00 on weekdays, disable the 'Office Window' privacy mask so security can monitor the full scene outside business hours. Paired with the morning enable rule.",
  "enabled": true,
  "trigger_logic": "OR",
  "trigger_window": 0,
  "condition_logic": "AND",
  "cooldown": 0,
  "max_executions": 1,
  "max_exec_period": "day",
  "triggers": [
    {
      "type": "schedule",
      "schedule_type": "daily_time",
      "daily_time": "18:00",
      "days": [1, 2, 3, 4, 5]
    }
  ],
  "conditions": [
    {
      "type": "variable_compare",
      "name": "system.privacy_mode",
      "op": "ne",
      "value": "override"
    }
  ],
  "actions": [
    {
      "type": "privacy_mask",
      "mask_id": "Office Window",
      "channel": 1,
      "enabled": false
    }
  ]
}
